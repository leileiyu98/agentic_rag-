
# 复制此文件为 .env 并填入你的真实 API 密钥
# cp .env.example .env
# ============================================


# ============================================
# LLM 大语言模型配置 (必需)
# ============================================


# OpenAI 兼容格式的 API 密钥
# 可以是 Moonshot、OpenAI、DeepSeek 等
OPENAI_API_KEY=your_api_key_here

# API 基础地址
# Moonshot: https://api.moonshot.cn
# OpenAI: https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
OPENAI_BASE_URL=https://api.moonshot.cn

# 模型名称
# Moonshot: moonshot-v1-8k, moonshot-v1-32k, moonshot-v1-128k
# OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# DeepSeek: deepseek-chat, deepseek-coder
LLM_MODEL=moonshot-v1-8k

# 模型提供商
# 可选: openai, moonshot, deepseek
LLM_PROVIDER=moonshot

# 温度参数 (0.0 - 2.0)
# 值越小回答越确定，值越大回答越创造性
TEMPERATURE=0.3


# ============================================
# Embedding 向量嵌入配置 (必需)
# ============================================

# Embedding API 密钥
# 默认使用阿里云 DashScope
EMBEDDING_API_KEY=your_embedding_api_key_here

# Embedding 基础地址
# DashScope: https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Embedding 模型名称
# DashScope 可选: text-embedding-v1, text-embedding-v2, text-embedding-v3
EMBEDDING_MODEL=text-embedding-v3


# ============================================
# 数据库配置
# ============================================

# PostgreSQL 连接 URL
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://rag_user:rag_password@localhost:5432/rag_db


# ============================================
# Milvus 向量数据库配置
# ============================================

# Milvus 主机地址
# Docker 部署默认使用 localhost
MILVUS_HOST=localhost

# Milvus 端口
MILVUS_PORT=19530


# ============================================
# LangSmith 监控配置 (可选)
# ============================================
# 用于追踪和调试 LangChain 调用，不是必需的

# LANGCHAIN_API_KEY=your_langsmith_api_key
# LANGCHAIN_PROJECT=rag-plus
# LANGCHAIN_TRACING_V2=true


# ============================================
# 前端配置 (Vite 需要 VITE_ 前缀)
# ============================================

# 后端 API 地址
VITE_API_BASE_URL=http://localhost:8000
